# Production build (used by `vite build`, i.e. the Netlify deploy).
# There is no real data backend deployed — only the AI Netlify Functions — so the
# data layer runs on the in-memory mock. AI calls the real functions.

# Mock the data layer (recipes / ingredients / pantry / meal plan).
VITE_USE_MOCK_DATA=false

# Use the REAL AI functions in production. Requires ANTHROPIC_API_KEY to be set in
# Netlify → Site settings → Environment variables. If you haven't added the key
# yet, set this to true to stub the AI features instead.
VITE_USE_MOCK_AI=false
