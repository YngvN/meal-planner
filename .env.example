# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Use the in-memory mock data layer (true) or a real backend (false).
VITE_USE_MOCK_DATA=true
# Base URL for the data backend.
VITE_API_BASE_URL=http://localhost:3001/api
# Mock the AI features independently of the data layer. If unset, falls back to
# VITE_USE_MOCK_DATA. Set to false in production to call the real AI functions
# while the data layer stays mocked (see .env.production).
VITE_USE_MOCK_AI=true
# Optional override for the AI serverless endpoints (defaults to /api/ai).
# VITE_AI_API_BASE_URL=/api/ai

# ─── Server-only (Netlify Functions) ───────────────────────────────────────────
# Anthropic API key used by the netlify/functions/ai-* functions (served at
# /api/ai/*). NEVER prefix with VITE_ — that would bundle it into the client.
# Set this in Netlify: Site settings → Environment variables. For local testing
# with real calls, put it in a gitignored .env and run `netlify dev`.
ANTHROPIC_API_KEY=
