# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Use the in-memory mock data layer (true) or a real Supabase backend (false).
VITE_USE_MOCK_DATA=false

# Supabase project URL — the JS client derives PostgREST/auth paths from this.
# Set in Netlify: Site configuration → Environment variables → VITE_SUPABASE_URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key — safe to use client-side (RLS controls access).
# Found in Supabase Dashboard → Settings → API → Project API keys → anon/public.
# Set in Netlify: Site configuration → Environment variables → VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_ANON_KEY=

# Mock the AI features independently of the data layer.
# Set to false in production to call the real Netlify AI functions.
VITE_USE_MOCK_AI=false

# ─── Server-only (Netlify Functions) ───────────────────────────────────────────
# Anthropic API key — used by netlify/functions/ai-* for AI features.
# NEVER prefix with VITE_ — that would bundle it into the client bundle.
# Set in Netlify: Site configuration → Environment variables → ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# Supabase service-role key — used by Netlify functions to verify JWTs and
# perform admin queries. NEVER expose this to the client.
# Found in Supabase Dashboard → Settings → API → service_role (secret).
# Set in Netlify: Site configuration → Environment variables → SUPABASE_SERVICE_KEY
SUPABASE_SERVICE_KEY=

# Supabase URL for server-side use in Netlify functions (same value as VITE_SUPABASE_URL).
# Set in Netlify: Site configuration → Environment variables → SUPABASE_URL
SUPABASE_URL=https://your-project.supabase.co
