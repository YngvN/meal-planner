# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Use the in-memory mock data layer (true) or a real backend (false).
VITE_USE_MOCK_DATA=false

# Supabase project URL — the JS client derives the PostgREST/auth paths from this.
VITE_SUPABASE_URL=https://hungri-database.nykas.me

# Supabase anon key — safe to commit (RLS controls access).
# Found in Supabase Dashboard → Settings → API → Project API keys → anon/public.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Mock the AI features independently of the data layer. If unset, falls back to
# VITE_USE_MOCK_DATA. Set to false in production to call the real AI functions.
VITE_USE_MOCK_AI=false
# Optional override for the AI serverless endpoints (defaults to /api/ai).
# VITE_AI_API_BASE_URL=/api/ai

# ─── Server-only (Netlify Functions) ───────────────────────────────────────────
# Anthropic API key used by netlify/functions/ai-* (served at /api/ai/*).
# NEVER prefix with VITE_ — that would bundle it into the client.
# Set in Netlify: Site settings → Environment variables.
ANTHROPIC_API_KEY=
