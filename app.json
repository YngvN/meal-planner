{
  "expo": {
    "name": "Meal Planner",
    "slug": "meal-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "meal-planner",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mealplanner.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mealplanner.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Meal Planner needs camera access to scan barcodes and photograph ingredients."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Meal Planner needs photo library access to select recipe and product images.",
          "cameraPermission": "Meal Planner needs camera access to photograph recipes and nutrition labels."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
